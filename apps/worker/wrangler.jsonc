{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aipm",
  "main": "src/index.ts",
  "account_id": "__CLOUDFLARE_ACCOUNT_ID__",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  // Default to shadow mode; flip per capability after reviewing the log.
  "vars": {
    // Global shadow stays on; working-notes is flipped live per-capability.
    // Set a capability var to "false" to go live, anything else keeps it shadowed.
    "SHADOW_GLOBAL": "true",
    "SHADOW_WORKING_NOTES": "false",
    "SHADOW_NUDGES": "false",
    "SHADOW_DIGEST": "false",
    "SHADOW_ORG_ROLLUP": "false",
    // Workers AI model (gpt-oss-120b via /ai/run dynamic format detection).
    "AI_MODEL": "@cf/openai/gpt-oss-120b",
    // LLM-judged reply checks (mentioned_no_response). Flip to "true" to enable.
    "LLM_JUDGE": "true",
    // AI Gateway slug for caching/observability. "default" is auto-used by the
    // AI binding on first call; create a named gateway in the dashboard to
    // customize caching/rate-limits, then change this.
    "AI_GATEWAY_ID": "default",
    // Abuse/cost controls. The member-trigger gate drops events from anyone not
    // in IDENTITY_ROSTER before any spend; set to "false" only on a fully
    // trusted (e.g. private) repo. The LLM budget caps are a backstop against
    // runaway loops/floods; set a window to "0" to disable it.
    "REQUIRE_MEMBER_TRIGGER": "true",
    "LLM_PER_MINUTE_BUDGET": "60",
    "LLM_DAILY_BUDGET": "1000",
    // Hard wall-clock bound (ms) on one LLM completion under the cluster lock.
    "LLM_REQUEST_TIMEOUT_MS": "30000",
    // Optional Slack channel id for the daily org pulse, e.g. "C0123456789".
    // "ORG_ROLLUP_CHANNEL_ID": "C0123456789"
    // GITHUB_APP_CLIENT_ID + the GitHub App/Slack secrets are set by the
    // deployment owner via Wrangler or deployer-owned CI, not committed here.
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "aipm",
      "database_id": "__AIPM_D1_DATABASE_ID__",
      "migrations_dir": "migrations",
    },
  ],

  "kv_namespaces": [
    {
      "binding": "DELIVERY_DEDUPE",
      "id": "__AIPM_DELIVERY_DEDUPE_KV_ID__",
    },
    {
      "binding": "INSTALL_TOKENS",
      "id": "__AIPM_INSTALL_TOKENS_KV_ID__",
    },
  ],

  "queues": {
    "producers": [{ "binding": "INGEST_QUEUE", "queue": "aipm-ingest" }],
    "consumers": [
      {
        "queue": "aipm-ingest",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3,
        // Bound concurrent processing: caps the LLM-spend *rate* under a flood or
        // a large sweep, and keeps the KV budget counter accurate (few concurrent
        // writers). Raise only with a strongly-consistent budget store.
        "max_concurrency": 3,
        "dead_letter_queue": "aipm-ingest-dlq",
      },
    ],
  },

  "durable_objects": {
    "bindings": [
      { "name": "CLUSTER_COORDINATOR", "class_name": "ClusterCoordinator" },
      { "name": "MERGE_REGISTRY", "class_name": "MergeRegistry" },
    ],
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ThreadCoordinator"] },
    {
      "tag": "v2",
      "deleted_classes": ["ThreadCoordinator"],
      "new_sqlite_classes": ["ClusterCoordinator", "MergeRegistry"],
    },
  ],

  "triggers": {
    // */30 = staleness/draft sweep; 0 14 = daily per-person digest (DESIGN §8).
    "crons": ["*/30 * * * *", "0 14 * * *"],
  },

  "ai": { "binding": "AI", "remote": true },
}
